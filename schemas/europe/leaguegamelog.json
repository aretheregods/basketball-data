{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EuropeLeagueGameLog",
  "description": "Schema for European leagues schedule/gamelog",
  "type": "object",
  "properties": {
    "games": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "gameId": { "type": "string" },
          "competitionId": { "type": "string" },
          "homeTeam": { "type": "string" },
          "awayTeam": { "type": "string" },
          "date": { "type": "string" }
        },
        "required": ["gameId", "competitionId", "homeTeam", "awayTeam"]
      }
    }
  },
  "required": ["games"]
}
