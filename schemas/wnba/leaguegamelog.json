{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WNBALeagueGameLog",
  "description": "Schema for WNBA Full Schedule (Data WNBA)",
  "type": "object",
  "properties": {
    "lscd": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "mscd": {
            "type": "object",
            "properties": {
              "mon": { "type": "string" },
              "g": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "gid": { "type": "string" },
                    "gcode": { "type": "string" },
                    "v": {
                      "type": "object",
                      "properties": {
                        "ta": { "type": "string" }
                      },
                      "required": ["ta"]
                    },
                    "h": {
                      "type": "object",
                      "properties": {
                        "ta": { "type": "string" }
                      },
                      "required": ["ta"]
                    }
                  },
                  "required": ["gid", "gcode", "v", "h"]
                }
              }
            },
            "required": ["g"]
          }
        },
        "required": ["mscd"]
      }
    }
  },
  "required": ["lscd"]
}
